# ─── Clipper AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# For Docker: redis://redis:6379/0
# For local:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Storage ────────────────────────────────────────────────────────────────────
# Directory where videos, audio, and clips are saved
# For Docker: /data
# For local:  ../data  (relative to backend/)
OUTPUT_DIR=../data

# ── YouTube / yt-dlp ─────────────────────────────────────────────────────────────
# If downloads fail with "Sign in to confirm you're not a bot", export Netscape cookies.txt
# from a logged-in browser session and point to it here (path inside the container / cwd).
# Docker: place the file in ./data on the host and use:
# YTDLP_COOKIES_FILE=/data/youtube_cookies.txt
# https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
YTDLP_COOKIES_FILE=

# ── AI — Groq API (Phase 2) ────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=
# 8b-instant = 6K TPM (strict). 3.3-70b-versatile = 12K TPM — better for long transcripts.
GROQ_MODEL=llama-3.3-70b-versatile
# Max characters of timestamped transcript sent to Groq (full prompt must fit TPM limit).
GROQ_TRANSCRIPT_MAX_CHARS=3800

# ── Whisper (Phase 2) ──────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# ── Pipeline defaults ──────────────────────────────────────────────────────────
MAX_VIDEO_DURATION_SECONDS=3600
DEFAULT_MIN_CLIP_DURATION=10
DEFAULT_MAX_CLIPS=10
DEFAULT_SCORE_THRESHOLD=0.5
